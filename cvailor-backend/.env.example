# ─────────────────────────────────────────────
#  Cvailor Backend — Environment Variables
# ─────────────────────────────────────────────

# App
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-long-random-secret-key-in-production

# Database
DATABASE_URL=postgresql+asyncpg://cvailor:cvailor@localhost:5432/cvailor
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# JWT
JWT_SECRET_KEY=change-me-to-a-long-random-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# AI Providers
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
AI_DEFAULT_PROVIDER=anthropic
AI_MODEL_FAST=claude-haiku-4-5-20251001
AI_MODEL_POWERFUL=claude-sonnet-4-6

# AWS S3 (for export file storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1
S3_BUCKET_NAME=cvailor-exports
S3_PRESIGNED_URL_EXPIRES=3600

# OAuth Providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# CORS
CORS_ORIGINS=http://localhost:3000,https://cvailor.com

# Email (future)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM=noreply@cvailor.com
